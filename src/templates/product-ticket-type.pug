extends partials/layout

//- Override default config variables
append config
  - var pageTitle = 'World of Beer'
  - var breadcrumbs = [{'title': 'Home', 'link': 'index.html'}, {'title': 'Food & Drink', 'link': '#'}, {'title': 'Tour', 'link': '#'}, {'title': 'This Event'}]

//- Page Content
block content
  // Steps
  .steps-wrap-container.container
    .steps-wrap.margin-bottom-2x
      .steps
        a(href='product.html').step.completed
          .step-inner
            span.step-addon: i.fas.fa-check
            | Tickets
        a(href='product-date-time.html').step.completed
          .step-inner
            span.step-addon: i.fas.fa-check
            | Date &amp; Time
        a(href='product-seating.html').step.completed
          .step-inner
            span.step-addon: i.fas.fa-check
            | Seating
        a(href='product-ticket-type.html').step.active
          .step-inner
            span.step-addon: i.fas.fa-arrow-down
            | Ticket Type
        a(href='product-add-to-cart.html').step
          .step-inner
            span.step-addon 5
            | Add To Cart
  
  // Content
  .container.padding-bottom-3x.mb-2
    .row.justify-content-center
      .col-xl-8.col-lg-10
        h2.text-center.text-sm-left Ticket Type
        p.text-lg.text-muted.text-center.text-sm-left Select your required ticket types and the quantity using the + and - buttons. 
        .alert.alert-info.text-center.text-sm-left.mb-3
          i.fas.fa-info-circle.text-lg &nbsp;&nbsp;
          span.text-lg There are only <strong>7 tickets</strong> left for this date and time.

        // Ticket
        .ticket-row
          .d-sm-flex.justify-content-between.text-center.text-sm-left
            div.w-35.pr-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Type
              h4 Kid Under 18
            div.text-center.px-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Price Each
              h4.text-normal R45.00
            div.px-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Select Qty
              .count-input
                a(href='#' data-action='decrease').incr-btn –
                input(type='text' value='1').quantity
                a(href='#' data-action='increase').incr-btn +
            div.px-2
              a(href='#').btn.btn-outline-primary Add
          .alert.alert-info.bg-0.border-0.py-2.px-0.text-center.text-sm-left
            i.fas.fa-info-circle.text-lg &nbsp;&nbsp;
            span.text-lg There are only <strong>3 tickets</strong> left of this type.

        // Ticket
        .ticket-row
          .d-sm-flex.justify-content-between.text-center.text-sm-left
            div.w-35.pr-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Type
              h4 Adult
            div.text-center.px-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Price Each
              h4.text-normal R125.00
            div.px-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Select Qty
              .count-input
                a(href='#' data-action='decrease').incr-btn –
                input(type='text' value='1').quantity
                a(href='#' data-action='increase').incr-btn +
            div.px-2
              a(href='#').btn.btn-outline-primary Add
