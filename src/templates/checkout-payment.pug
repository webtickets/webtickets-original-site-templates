extends partials/layout

//- Override default config variables
append config
  - var pageTitle = 'Checkout'
  - var isCardScript = true
  - var breadcrumbs = [{'title': 'Home', 'link': 'index.html'}, {'title': 'Checkout'}]

//- Page Content
block content
  .checkout-page.container.padding-bottom-3x.mb-2
    .row
      .col-xl-9.col-lg-8
        
        // Steps
        .steps-wrap.margin-bottom-2x
          .steps
            a(href='checkout-address.html').step.completed
              .step-inner
                span.step-addon: i.fas.fa-check
                | Address
            a(href='checkout-shipping.html').step.completed
              .step-inner
                span.step-addon: i.fas.fa-check
                | Shipping
            a(href='checkout-payment.html').step.active
              .step-inner
                span.step-addon: i.fas.fa-arrow-down
                | Payment
            a(href='checkout-review.html').step
              .step-inner
                span.step-addon 4
                | Review

        // Content
        h4 Choose Payment Method
        hr.padding-bottom-1x
        div(id='accordion' class='accordion' role='tablist')
          .card
            .card-header(role='tab')
              h6
                a(href='#card' data-toggle='collapse')
                  i.far.fa-credit-card
                  | Pay with Credit Card
            div(id='card' class='collapse show' data-parent='#accordion' role='tabpanel')
              .card-body
                p
                  | We accept following credit cards:&nbsp;
                  img(src='img/credit-cards.png' style='width: 120px;' alt='Cerdit Cards').d-inline-block.align-middle
                .card-wrapper
                form.interactive-credit-card.row
                  .form-group.col-sm-6
                    input(type='text' name='number' placeholder='Card Number' required).form-control
                  .form-group.col-sm-6
                    input(type='text' name='name' placeholder='Full Name' required).form-control
                  .form-group.col-sm-3
                    input(type='text' name='expiry' placeholder='MM/YY' required).form-control
                  .form-group.col-sm-3
                    input(type='text' name='cvc' placeholder='CVC' required).form-control
                  .col-sm-6
                    button(type='submit').btn.btn-outline-primary.btn-block.margin-top-none Submit
          .card
            .card-header(role='tab')
              h6
                a(href='#paypal' class='collapsed' data-toggle='collapse')
                  i.fab.fa-paypal
                  | Pay with PayPal
            div(id='paypal' class='collapse' data-parent='#accordion' role='tabpanel')
              .card-body
                p PayPal - the safer, easier way to pay
                form(method='post').row
                  .col-sm-6
                    .form-group
                      input(type='email' placeholder='E-mail' required).form-control
                  .col-sm-6
                    .form-group
                      input(type='password' placeholder='Password' required).form-control
                  .col-12
                    .d-flex.flex-wrap.justify-content-between.align-items-center
                      a(href='#').navi-link Forgot password?
                      button(type='submit').btn.btn-outline-primary.margin-top-none Log In
          .card
            .card-header(role='tab')
              h6
                a(href='#points' class='collapsed' data-toggle='collapse')
                  i.far.fa-money-bill-alt
                  | Redeem Credits
            div(id='points' class='collapse' data-parent='#accordion' role='tabpanel')
              .card-body
                p
                  | You currently have
                  span.text-medium  290
                  |  Credits to spend.
                .custom-control.custom-checkbox.d-block
                  input(type='checkbox' id='use_points').custom-control-input
                  label(for='use_points').custom-control-label Use my Credits to pay for this order.

        .checkout-footer.margin-top-1x
          .column
            a(href='checkout-shipping.html' class='btn btn-outline-secondary')
              i.fas.fa-arrow-left
              span.hidden-xs-down &nbsp;Back
          .column
            a(href='checkout-review.html' class='btn btn-primary')
              span.hidden-xs-down Continue&nbsp;
              i.fas.fa-arrow-right

      // Sidebar          
      .col-xl-3.col-lg-4
        include partials/checkout-sidebar    
