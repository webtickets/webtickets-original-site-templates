extends partials/layout

//- Override default config variables
append config
  - var pageTitle = 'Checkout'
  - var breadcrumbs = [{'title': 'Home', 'link': 'index.html'}, {'title': 'Checkout'}]

//- Page Content
block content
  .checkout-page.container.padding-bottom-3x.mb-2
    .row
      .col-xl-9.col-lg-8
        
        // Steps
        .steps-wrap.margin-bottom-2x
          .steps
            a(href='checkout-address.html').step.completed
              .step-inner
                span.step-addon: i.fas.fa-check
                | Address
            a(href='checkout-shipping.html').step.active
              .step-inner
                span.step-addon: i.fas.fa-arrow-down
                | Shipping
            a(href='checkout-payment.html').step
              .step-inner
                span.step-addon 3
                | Payment
            a(href='checkout-review.html').step
              .step-inner
                span.step-addon 4
                | Review

        // Content
        h4 Choose Shipping Method
        hr.padding-bottom-1x
        .table-responsive
          table.table.table-hover
            thead.thead-default
              tr
                th
                th Shipping method
                th Delivery time
                th Handling fee
            tbody
              tr
                td.align-middle
                  .custom-control.custom-radio.mb-0
                    input(type='radio' id='courier' name='shipping-method' checked).custom-control-input
                    label(for='courier').custom-control-label
                td.align-middle
                  span.text-medium Courier
                  br
                  span.text-muted.text-sm All Addresses(default zone), United States & Canada
                td.align-middle 2 - 4 days
                td.align-middle R22.50
              tr
                td.align-middle
                  .custom-control.custom-radio.mb-0
                    input(type='radio' id='local' name='shipping-method').custom-control-input
                    label(for='local').custom-control-label
                td.align-middle
                  span.text-medium Local Shipping
                  br
                  span.text-muted.text-sm All Addresses(default zone), United States & Canada
                td.align-middle up to one week
                td.align-middle R10.00
              tr
                td.align-middle
                  .custom-control.custom-radio.mb-0
                    input(type='radio' id='flat' name='shipping-method').custom-control-input
                    label(for='flat').custom-control-label
                td.align-middle
                  span.text-medium Flat Rate
                  br
                  span.text-muted.text-sm All Addresses(default zone)
                td.align-middle 5 - 7 days
                td.align-middle R33.85
              tr
                td.align-middle
                  .custom-control.custom-radio.mb-0
                    input(type='radio' id='ups' name='shipping-method').custom-control-input
                    label(for='ups').custom-control-label
                td.align-middle
                  span.text-medium UPS Ground Shipping
                  br
                  span.text-muted.text-sm All Addresses(default zone)
                td.align-middle 4 - 6 days
                td.align-middle R18.00
              tr
                td.align-middle
                  .custom-control.custom-radio.mb-0
                    input(type='radio' id='pickup' name='shipping-method').custom-control-input
                    label(for='pickup').custom-control-label
                td.align-middle
                  span.text-medium Local Pickup from store
                  br
                  span.text-muted.text-sm All Addresses(default zone)
                td.align-middle &mdash;
                td.align-middle R0.00
              tr
                td.align-middle
                  .custom-control.custom-radio.mb-0
                    input(type='radio' id='locker' name='shipping-method').custom-control-input
                    label(for='locker').custom-control-label
                td.align-middle
                  span.text-medium Pick Up at Webtickets Locker
                  br
                  span.text-muted.text-sm All Addresses(default zone), United States & Canada
                td.align-middle &mdash;
                td.align-middle R9.99
              tr
                td.align-middle
                  .custom-control.custom-radio.mb-0
                    input(type='radio' id='global' name='shipping-method').custom-control-input
                    label(for='global').custom-control-label
                td.align-middle
                  span.text-medium Webtickets Global Export
                  br
                  span.text-muted.text-sm All Addresses(default zone), outside United States
                td.align-middle 3 - 4 days;
                td.align-middle R25.00

        .checkout-footer.margin-top-1x
          .column
            a(href='checkout-address.html' class='btn btn-outline-secondary')
              i.fas.fa-arrow-left
              span.hidden-xs-down &nbsp;Back
          .column
            a(href='checkout-payment.html' class='btn btn-primary')
              span.hidden-xs-down Continue&nbsp;
              i.fas.fa-arrow-right

      // Sidebar          
      .col-xl-3.col-lg-4
        include partials/checkout-sidebar    
    
