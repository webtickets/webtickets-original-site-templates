extends partials/layout

//- Override default config variables
append config
  - var pageTitle = 'Browse by List'
  - var breadcrumbs = [{'title': 'Home', 'link': 'index.html'}, {'title': 'Browse by List'}]

//- Page Content
block content
  .container.padding-bottom-3x.mb-1
    .row

      // Products
      .col-xl-9.col-lg-8.order-lg-2

        // Shop Toolbar
        .shop-toolbar.padding-bottom-1x.mb-2
          .column
            .shop-sorting
              label(for='sorting') Sort by:
              select(id='sorting').form-control
                option Popularity
                option Low - High Price
                option High - Low Price
                option Avarage Rating
                option A - Z Order
                option Z - A Order
              span.text-muted Showing:&nbsp;
              span 1 - 12 items
          .column
            .shop-view
              a(href='shop-grid.html' class='grid-view')
                span
                span
                span
              a(href='shop-list.html' class='list-view active')
                span
                span
                span

        // Products List
        .products-list

          // Event
          .product-card.d-sm-flex.mb-30
            .product-card-thumb
              a(href='product.html')
                img(src='img/shop/th01.jpg' alt='Product')
              button(type='button' data-toggle='tooltip' title='Add to Likes').product-card-like
                i.far.fa-heart
            .product-card-body.pl-sm-4
              .product-card-meta Tue, Mar 27, 7PM
              h3.product-card-title: a(href='product.html') Event Title Here With Enough Space For Two Lines
              ul.product-card-category
                li.hidden-xs-down: a(href='#') Performance & Visual Art
                li.hidden-xs-down &gt;
                li: a(href='#') Theatre
              .product-card-price R45 - R414

