              a(href='product.html')
                img(src='img/shop/th13.jpg' alt='Product')
              button(type='button' data-toggle='tooltip' title='Add to Likes').product-card-like
                i.far.fa-heart
            .product-card-meta Tue, Mar 27, 7PM
            h3.product-card-title: a(href='product.html') Event Title Here With Enough Space For Two Lines
            ul.product-card-category
              li: a(href='#') Live Bands
