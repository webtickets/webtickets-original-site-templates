// Featured Events
section.fw-section.padding-bottom-4x
  .bg-angle.bg-inset-shadow-both(style='background-image: url(img/bg-pattern.png);')
  .container.pb-4
    h2.mb-2.pt-4
      i.fas.fa-star.text-primary &nbsp;
      | Featured Events
    p.text-lg We’ve hand picked the best events in each category. Click See More to see the full list.
    // Scrollable Menu
    .scrollable-menu.owl-carousel(data-owl-carousel='{ "nav": true, "dots": false, "autoWidth": true}')
      .scrollable-menu-item: a(href='#') All
      .scrollable-menu-item.active: a(href='#') Music
      .scrollable-menu-item: a(href='#') Performing &amp; Visual Arts
      .scrollable-menu-item: a(href='#') Sport &amp; Fitness
      .scrollable-menu-item: a(href='#') Tourism &amp; Outdoor
      .scrollable-menu-item: a(href='#') Food &amp; Drink
      .scrollable-menu-item: a(href='#') Film &amp; Media
      .scrollable-menu-item: a(href='#') Family &amp; Kids
      .scrollable-menu-item: a(href='#') Tourism &amp; Outdoor
      .scrollable-menu-item: a(href='#') Charities &amp; Causes
      .scrollable-menu-item: a(href='#') Business &amp; Professional
    
  // Events
  .container
    .owl-carousel.nav-outside(data-owl-carousel='{ "nav": true, "dots": false, "margin": 30, "autoHeight": true }')

      // Slide
