extends partials/layout

//- Override default config variables
append config
  - var pageTitle = 'Cart'
  - var breadcrumbs = [{'title': 'Home', 'link': 'index.html'}, {'title': 'Cart'}]

//- Page Content
block content
  .container.padding-bottom-3x.mb-1

    // Alert
    .alert.alert-info.alert-dismissible.fade.show.mb-4.text-center
      span(data-dismiss='alert').alert-close
        i.fas.fa-times
      i.far.fa-money-bill-alt
      | &nbsp;&nbsp;With this purchase you will earn <strong>290</strong> Credits.

    // Shopping Cart
    .shopping-cart
      
      // Item
      .item-row
        .d-md-flex.justify-content-between.align-items-start
          .text-center.text-md-left.p-2
            span.d-block.text-uppercase.text-gray.text-medium.mb-2 Event
            .product-item
              a(href='product.html').product-thumb
                img(src='img/shop/th01.jpg', alt='Product')
              .product-info
                h4.product-title
                  a(href='product.html') Event Title Goes Here
                .text-lg.text-info R45 - R414
          .text-center.text-medium.p-2
            span.d-block.text-uppercase.text-gray.mb-2 Quantity
            span 1
          .text-center.text-medium.p-2
            span.d-block.text-uppercase.text-gray.mb-2 Date
            span.text-lg Tue, Mar 27, 7PM
          .text-center.text-medium.p-2
            span.d-block.text-uppercase.text-gray.mb-2 Price
            span.text-lg R43.90
          .text-center.p-2
            span.d-block.text-uppercase.text-gray.text-medium.mb-1 Timer
            .countdown(data-date-time='09/25/2018 22:00:00')
              .item
                .hours 00
                span.hours_ref Hours
              .item
                .minutes 00
                span.minutes_ref Mins
              .item
                .seconds 00
                span.seconds_ref Secs
          .text-center.align-self-center.px-4
            a(href='#' data-toggle='tooltip' title='Remove').btn-remove
              i.far.fa-times-circle
      
      // Item
      .item-row
        .d-md-flex.justify-content-between.align-items-start
          .text-center.text-md-left.p-2
            span.d-block.text-uppercase.text-gray.text-medium.mb-2 Event
            .product-item
              a(href='product.html').product-thumb
                img(src='img/shop/th02.jpg', alt='Product')
              .product-info
                h4.product-title
                  a(href='product.html') Event Title Goes Here
