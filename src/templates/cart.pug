          .text-center.text-medium.p-2
            span.d-block.text-uppercase.text-gray.mb-2 Price
            span.text-lg R24.89
          .text-center.p-2
            span.d-block.text-uppercase.text-gray.text-medium.mb-1 Timer
            .countdown(data-date-time='09/25/2018 22:00:00')
              .item
                .hours 00
                span.hours_ref Hours
              .item
                .minutes 00
                span.minutes_ref Mins
              .item
                .seconds 00
                span.seconds_ref Secs
          .text-center.align-self-center.px-4
            a(href='#' data-toggle='tooltip' title='Remove').btn-remove
