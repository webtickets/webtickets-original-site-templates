            .w-10.text-center.pr-2.pb-2.pb-sm-0
              i.ticket-icon.fas.fa-ticket-alt
            .text-center.px-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Quantity
              h4.text-normal
                | 1
                a(href='#' data-toggle='tooltip' title='Edit').btn-edit
                  i.far.fa-edit
            .w-30.text-center.pr-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Type
              h4.text-normal
                | Kid Under 18
                a(href='#' data-toggle='tooltip' title='Edit').btn-edit
                  i.far.fa-edit
            .text-center.text-sm-left.px-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Seat
              h4.text-normal
                | J34
                a(href='#' data-toggle='tooltip' title='Edit').btn-edit
                  i.far.fa-edit
            .text-center.text-sm-left.px-2.pb-2.pb-sm-0
              span.d-block.text-uppercase.text-gray.text-medium.mb-1 Price
              h4.text-normal R45.00
            .w-10.text-center.px-2
              a(href='#' data-toggle='tooltip' title='Remove').btn-remove
                i.far.fa-times-circle
        .d-sm-flex.justify-content-between.mt-4
          .alert.alert-info.bg-0.border-0.p-0.pr-3.text-center.text-sm-left
            i.fas.fa-info-circle.text-lg &nbsp;&nbsp;
            span.text-lg You can continue shopping once you’ve added these to your cart.
          h3.h4.text-center.text-sm-right.pt-2.pt-sm-0 Subtotal: <span class='text-normal'>R295.00</span>
        .text-center.text-sm-right.pt-3
          a(href='#').btn.btn-primary Add To Cart
          
    // Related Products
    h2.mb-2.pt-5.text-center.text-sm-left
      i.fas.fa-star.text-primary &nbsp;
      | You May Also Like
    p.text-lg.pb-2 If you like this event, here are a few more that may interest you.
    include partials/products-carousel-1