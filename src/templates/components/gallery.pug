extends ../partials/layout

//- Override default config variables
append config
  - var isComponentHeader = true
  - var isHeader = false
  - var pageTitle = 'Gallery'
  - var isFooter = false
  - var isNestedFile = true
  - var isGallery = true
  - var breadcrumbs = [{'title': 'Components', 'link': 'index.html'}, {'title': 'Gallery'}]

//- Page Content
