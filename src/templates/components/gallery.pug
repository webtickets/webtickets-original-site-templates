    .row
      .col-lg-9.col-md-8.order-md-2
        h6.text-muted.text-normal.text-uppercase With Gutters
        hr.margin-bottom-1x
        .gallery-wrapper
          .row
            .col-md-4.col-sm-6
              .gallery-item
                a(href='../img/gallery/03.jpg' data-size='1000x667')
                  i.fas.fa-search-plus
                  img(src='../img/gallery/th03.jpg' alt='Image')
                span.caption Image Caption #1
            .col-md-4.col-sm-6
              .gallery-item
                a(href='../img/gallery/02.jpg' data-size='1000x667')
                  i.fas.fa-search-plus
                  img(src='../img/gallery/th02.jpg' alt='Image')
                span.caption Image Caption #2
            .col-md-4.col-sm-6
              .gallery-item
