          span.mb-subtitle Download on the
          span.mb-title App Store
        a(href='#').market-button.google-button
          span.mb-subtitle Download on the
          span.mb-title Google Play
        a(href='#').market-button.windows-button
          span.mb-subtitle Download on the
          span.mb-title Windows Store
        a(href='#').market-button.amazon-button
          span.mb-subtitle Order now at
          span.mb-title Amazon.com
        a(href='#').market-button.blackberry-button
          span.mb-subtitle Download on the
          span.mb-title Blackberry
        div(style='padding: 30px 20px 15px 20px;').bg-dark.margin-top-1x
