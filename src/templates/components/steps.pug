extends ../partials/layout

//- Override default config variables
append config
  - var isComponentHeader = true
  - var isHeader = false
  - var pageTitle = 'Steps'
  - var isFooter = false
  - var isNestedFile = true
  - var breadcrumbs = [{'title': 'Components', 'link': 'index.html'}, {'title': 'Steps'}]

//- Page Content
block content
  .container.padding-bottom-3x.mb-2
    .row
      .col-lg-9.col-md-8.order-md-2
        h6.text-muted.text-normal.text-uppercase Basic Example
        hr.margin-bottom-1x.pb-2
        .steps-wrap
          .steps
            a(href='#').step
              .step-inner
                span.step-addon 1
                | Tickets
            a(href='#').step
              .step-inner
                span.step-addon 2
                | Date &amp; Time
            a(href='#').step
              .step-inner
                span.step-addon 3
                | Seating
            a(href='#').step
              .step-inner
                span.step-addon 4
                | Ticket Type
        h6.text-muted.text-normal.text-uppercase.padding-top-2x Active Step
        hr.margin-bottom-1x.pb-2
        .steps-wrap
          .steps
            a(href='#').step.active
              .step-inner
                span.step-addon: i.fas.fa-arrow-down
                | Tickets
            a(href='#').step
              .step-inner
                span.step-addon 2
                | Date &amp; Time
            a(href='#').step
              .step-inner
                span.step-addon 3
                | Seating
            a(href='#').step
              .step-inner
                span.step-addon 4
                | Ticket Type
        h6.text-muted.text-normal.text-uppercase.padding-top-2x Completed Steps
        hr.margin-bottom-1x.pb-2
        .steps-wrap
          .steps
            a(href='#').step.completed
              .step-inner
                span.step-addon: i.fas.fa-check
                | Tickets
            a(href='#').step.completed
              .step-inner
                span.step-addon: i.fas.fa-check
                | Date &amp; Time
            a(href='#').step.active
              .step-inner
                span.step-addon: i.fas.fa-arrow-down
                | Seating
            a(href='#').step
              .step-inner
                span.step-addon 4
                | Ticket Type
      
      .col-lg-3.col-md-4.order-md-1
        //- Side Menu
        include ../partials/components-menu