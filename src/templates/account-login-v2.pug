extends partials/layout

//- Override default config variables
append config
  - var pageTitle = 'Sign In'
  - var breadcrumbs = [{'title': 'Home', 'link': 'index.html'}, {'title': 'Sign In'}]

//- Page Content
block content
  //- Inline styles for sign-in form
  style.
    /* Google Sign-In Button (official) */
    .gsi-material-button {
      -moz-user-select: none;
      -webkit-user-select: none;
      -ms-user-select: none;
      -webkit-appearance: none;
      background-color: WHITE;
      background-image: none;
      border: 1px solid #747775;
      -webkit-border-radius: 20px;
      border-radius: 20px;
      -webkit-box-sizing: border-box;
      box-sizing: border-box;
      color: #1f1f1f;
      cursor: pointer;
      font-family: 'Roboto', arial, sans-serif;
      font-size: 14px;
      height: 40px;
      letter-spacing: 0.25px;
      outline: none;
      overflow: hidden;
      padding: 0 12px;
      position: relative;
      text-align: center;
      -webkit-transition: background-color .218s, border-color .218s, box-shadow .218s;
      transition: background-color .218s, border-color .218s, box-shadow .218s;
      vertical-align: middle;
      white-space: nowrap;
      width: auto;
      max-width: 400px;
      min-width: min-content;
    }
    .gsi-material-button .gsi-material-button-icon {
      height: 20px;
      margin-right: 10px;
      min-width: 20px;
      width: 20px;
    }
    .gsi-material-button .gsi-material-button-content-wrapper {
      -webkit-align-items: center;
      align-items: center;
      display: flex;
      -webkit-flex-direction: row;
      flex-direction: row;
      -webkit-flex-wrap: nowrap;
      flex-wrap: nowrap;
      height: 100%;
      justify-content: center;
      position: relative;
      width: 100%;
    }
    .gsi-material-button .gsi-material-button-contents {
      -webkit-flex-grow: 0;
      flex-grow: 0;
      font-family: 'Roboto', arial, sans-serif;
      font-weight: 500;
      overflow: hidden;
      text-overflow: ellipsis;
      vertical-align: top;
    }
    .gsi-material-button .gsi-material-button-state {
      -webkit-transition: opacity .218s;
      transition: opacity .218s;
      bottom: 0;
      left: 0;
      opacity: 0;
      position: absolute;
      right: 0;
      top: 0;
    }
    .gsi-material-button:disabled {
      cursor: default;
      background-color: #ffffff61;
      border-color: #1f1f1f1f;
    }
    .gsi-material-button:disabled .gsi-material-button-contents {
      opacity: 38%;
    }
    .gsi-material-button:disabled .gsi-material-button-icon {
      opacity: 38%;
    }
    .gsi-material-button:not(:disabled):active .gsi-material-button-state,
    .gsi-material-button:not(:disabled):focus .gsi-material-button-state {
      opacity: 0;
    }
    .gsi-material-button:not(:disabled):hover {
      -webkit-box-shadow: 0 1px 2px 0 rgba(60, 64, 67, .30), 0 1px 3px 1px rgba(60, 64, 67, .15);
      box-shadow: 0 1px 2px 0 rgba(60, 64, 67, .30), 0 1px 3px 1px rgba(60, 64, 67, .15);
    }
    .gsi-material-button:not(:disabled):hover .gsi-material-button-state {
      opacity: 0;
    }

    /* Google button overrides to match design */
    .signin-google-btn {
      width: 100%;
      max-width: 100%;
      height: 50px;
      border-radius: 25px;
      border-color: #c1272d;
      font-size: 16px;
    }
    .signin-google-btn .gsi-material-button-contents {
      color: #c1272d;
      font-size: 16px;
      font-weight: 600;
    }
    .signin-google-btn .gsi-material-button-icon {
      height: 24px;
      width: 24px;
      min-width: 24px;
    }

    /* Facebook button */
    .signin-facebook-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 50px;
      border-radius: 25px;
      border: 1px solid #1877F2;
      background: #fff;
      color: #1877F2;
      font-family: 'Roboto', arial, sans-serif;
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.25px;
      cursor: pointer;
      margin-top: 12px;
      transition: background-color .218s, box-shadow .218s;
    }
    .signin-facebook-btn:hover {
      box-shadow: 0 1px 2px 0 rgba(60, 64, 67, .30), 0 1px 3px 1px rgba(60, 64, 67, .15);
    }
    .signin-facebook-btn i {
      font-size: 20px;
      margin-right: 10px;
    }

    /* Sign-in card */
    .signin-card {
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 2px 16px rgba(0,0,0,0.07);
      padding: 35px 30px;
    }

    /* Helper text — tight to the button above, clear gap below so it
       visually groups with its own button rather than the next one. */
    .signin-helper-text {
      text-align: center;
      color: #666;
      font-size: 14px;
      margin: 1px 0 18px 0;
    }
    /* When an OR divider follows a helper (via the hidden form sibling),
       trim its top margin so the gap doesn't double-up. */
    .signin-helper-text + form + .signin-or-divider {
      margin-top: 1px;
    }

    /* OR divider */
    .signin-or-divider {
      display: flex;
      align-items: center;
      margin: 20px 0;
    }
    .signin-or-divider::before,
    .signin-or-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #bbb;
    }
    .signin-or-divider span {
      padding: 0 16px;
      color: #666;
      font-size: 15px;
      font-weight: 500;
    }

    /* Phone button */
    .signin-btn-phone {
      width: 100%;
      height: 52px;
      border-radius: 26px;
      border: 2px solid #7fbd52;
      background: transparent;
      color: #7fbd52;
      font-size: 16px;
      font-weight: 500;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background-color 0.2s, color 0.2s;
    }
    .signin-btn-phone:hover {
      background: #7fbd52;
      color: #fff;
    }
    .signin-btn-phone i,
    .signin-btn-login i {
      font-size: 20px;
      margin-right: 6px;
    }

    /* Input fields */
    .signin-input-group {
      position: relative;
      margin-bottom: 16px;
    }
    .signin-input-icon {
      position: absolute;
      left: 20px;
      top: 50%;
      transform: translateY(-50%);
      color: #7fbd52;
      font-size: 15px;
    }
    .signin-input {
      width: 100%;
      height: 50px;
      border: 1px solid #ddd;
      border-radius: 25px;
      padding: 0 50px 0 48px;
      font-size: 15px;
      color: #333;
      outline: none;
      transition: border-color 0.2s;
    }
    .signin-input:focus {
      border-color: #7fbd52;
    }
    .signin-input::placeholder {
      color: #aaa;
    }

    /* Password toggle */
    .signin-toggle-password {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: #7fbd52;
      font-size: 15px;
      padding: 4px;
    }
    .signin-toggle-password:hover {
      color: #6aa842;
    }

    /* Remember me row */
    .signin-card .custom-control-label {
      font-size: 14px;
      color: #555;
    }
    .signin-card .custom-control-input:checked ~ .custom-control-label::before {
      background-color: #7fbd52;
      border-color: #7fbd52;
    }
    .signin-forgot-text {
      font-size: 14px;
      color: #555;
    }
    .signin-forgot-link {
      color: #7fbd52;
      text-decoration: underline;
    }
    .signin-forgot-link:hover {
      color: #6aa842;
    }

    /* Login with email button */
    .signin-btn-login {
      width: 100%;
      height: 52px;
      border-radius: 26px;
      border: 2px solid #7fbd52;
      background: transparent;
      color: #7fbd52;
      font-size: 16px;
      font-weight: 500;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background-color 0.2s, color 0.2s;
    }
    .signin-btn-login:hover {
      background: #7fbd52;
      color: #fff;
    }
    /* Filled variant — used for primary commit actions inside a form
       (SEND SIGN IN LINK / SEND OTP CODE / SIGN IN). */
    .signin-btn-login--filled {
      background: #7fbd52;
      color: #fff;
      transition: background-color 0.15s, transform 0.05s;
    }
    .signin-btn-login--filled:hover {
      background: #6ba843;
      color: #fff;
    }
    .signin-btn-login--filled:active {
      background: #5a9338;
      color: #fff;
      transform: scale(0.98);
    }
    .signin-btn-login--filled:disabled,
    .signin-btn-login--filled:disabled:hover {
      background: #7fbd52;
      color: #fff;
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    /* Back button + submit row (shown after an option is chosen) */
    .signin-form-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .signin-form-actions .signin-btn-login {
      flex: 1 1 auto;
      width: auto;
    }
    .signin-btn-back {
      flex-shrink: 0;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 2px solid #7fbd52;
      background: transparent;
      color: #7fbd52;
      font-size: 16px;
      padding: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background-color 0.2s, color 0.2s;
    }
    .signin-btn-back:hover {
      background: #7fbd52;
      color: #fff;
    }

    /* Disabled submit state (error flow) */
    .signin-btn-login:disabled,
    .signin-btn-phone:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .signin-btn-login:disabled:hover,
    .signin-btn-phone:disabled:hover {
      background: transparent;
      color: #7fbd52;
    }

    /* Unknown-account error box shown inside magic/cell forms */
    .signin-error-box {
      background: #fdf2f2;
      border: 1px solid #f5c2c2;
      border-radius: 12px;
      padding: 14px 16px;
      margin-bottom: 16px;
    }
    .signin-error-message {
      color: #a0332f;
      font-size: 14px;
      line-height: 1.45;
      margin: 0 0 10px 0;
    }
    .signin-error-box .custom-control {
      min-height: auto;
    }

    /* Dev toggle — fixed bottom-right, simulates an unknown account */
    .signin-dev-toggle {
      position: fixed;
      bottom: 16px;
      right: 16px;
      background: #fff;
      border: 1px dashed #aaa;
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 12px;
      color: #555;
      z-index: 1000;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    .signin-dev-toggle label {
      display: flex;
      align-items: center;
      gap: 6px;
      margin: 0;
      cursor: pointer;
    }
    .signin-dev-toggle input {
      margin: 0;
    }

    /* Success state (shown after a successful magic/cell submit) */
    .signin-form-success {
      text-align: center;
      padding: 8px 0 4px 0;
    }
    .signin-success-icon {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: #eaf4df;
      color: #7fbd52;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 30px;
      margin: 0 auto 18px auto;
    }
    .signin-success-title {
      font-size: 22px;
      font-weight: 600;
      color: #333;
      margin: 0 0 10px 0;
    }
    .signin-success-text {
      font-size: 14px;
      color: #666;
      line-height: 1.5;
      margin: 0 auto 22px auto;
      max-width: 320px;
    }
    .signin-success-text strong {
      color: #333;
      word-break: break-word;
    }

    /* 6-digit OTP input row */
    .signin-otp-group {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 22px;
    }
    .signin-otp-input {
      width: 44px;
      height: 54px;
      border: 1px solid #ddd;
      border-radius: 10px;
      text-align: center;
      font-size: 22px;
      font-weight: 600;
      color: #333;
      outline: none;
      padding: 0;
      background: #fff;
      transition: border-color 0.2s;
    }
    .signin-otp-input:focus {
      border-color: #7fbd52;
    }

    /* Responsive */
    @media (max-width: 575px) {
      .signin-card {
        padding: 25px 20px;
      }
    }

  .container.padding-bottom-3x.mb-2
    .row.justify-content-center
      .col-lg-6.col-md-8

        .signin-card

          //- Google Sign-In Button (official markup)
          button.gsi-material-button.signin-google-btn
            .gsi-material-button-state
            .gsi-material-button-content-wrapper
              .gsi-material-button-icon
                svg(version='1.1' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 48 48' style='display: block;')
                  path(fill='#EA4335' d='M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z')
                  path(fill='#4285F4' d='M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z')
                  path(fill='#FBBC05' d='M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z')
                  path(fill='#34A853' d='M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z')
                  path(fill='none' d='M0 0h48v48H0z')
              span.gsi-material-button-contents Continue with Google
              span(style='display: none;') Continue with Google

          //- Facebook Sign-In Button (custom, follows brand guidelines)
          // button.signin-facebook-btn(type='button')
          //   i.fab.fa-facebook-f
          //   span Sign in with Facebook

          .signin-or-divider
            span OR

          //- Continue with Email (magic link)
          button.btn.signin-btn-login#signin-magic-toggle(type='button' onclick='showSignInForm("magic")')
            i.fas.fa-paper-plane
            | &nbsp; CONTINUE WITH EMAIL

          p.signin-helper-text#signin-magic-helper We'll email a magic link to sign you in instantly

          //- Magic link form (hidden by default)
          form#signin-magic-form(method='post' style='display:none;')
            .signin-form-entry#signin-magic-entry
              .signin-input-group
                i.fas.fa-envelope.signin-input-icon
                input.signin-input(type='email' autocomplete='email' placeholder='Email' required)

              .signin-error-box#signin-magic-error(style='display:none;')
                p.signin-error-message We don't recognize this email. Please confirm you're not a robot to continue.
                .custom-control.custom-checkbox
                  input.custom-control-input(type='checkbox' id='signin-magic-robot')
                  label.custom-control-label(for='signin-magic-robot') I'm not a robot

              .signin-form-actions
                button.signin-btn-back(type='button' onclick='showAllSignInOptions()' aria-label='Back')
                  i.fas.fa-arrow-left
                button.btn.signin-btn-login.signin-btn-login--filled(type='submit')
                  i.fas.fa-paper-plane
                  | &nbsp; SEND SIGN IN LINK TO MY EMAIL

            .signin-form-success#signin-magic-success(style='display:none;')
              .signin-success-icon
                i.fas.fa-paper-plane
              h3.signin-success-title Check your email
              p.signin-success-text We sent a sign-in link to #[strong#signin-magic-display-value]. Click the link in the email to finish signing in.
              button.btn.signin-btn-login(type='button' onclick='showAllSignInOptions()')
                i.fas.fa-arrow-left
                | &nbsp; USE A DIFFERENT EMAIL

          //- Continue with Phone
          button.btn.signin-btn-phone#signin-cell-toggle(type='button' onclick='showSignInForm("cell")')
            i.fas.fa-mobile-alt
            | &nbsp; CONTINUE WITH CELL

          p.signin-helper-text#signin-cell-helper We'll send an SMS with a code to sign in

          //- Cell form (hidden by default)
          form#signin-cell-form(method='post' style='display:none;')
            .signin-form-entry#signin-cell-entry
              .signin-input-group
                i.fas.fa-mobile-alt.signin-input-icon
                input.signin-input(type='tel' inputmode='tel' autocomplete='tel' placeholder='Cell phone number' required)

              .signin-error-box#signin-cell-error(style='display:none;')
                p.signin-error-message We don't recognize this cell number. Please confirm you're not a robot to continue.
                .custom-control.custom-checkbox
                  input.custom-control-input(type='checkbox' id='signin-cell-robot')
                  label.custom-control-label(for='signin-cell-robot') I'm not a robot

              .signin-form-actions
                button.signin-btn-back(type='button' onclick='showAllSignInOptions()' aria-label='Back')
                  i.fas.fa-arrow-left
                button.btn.signin-btn-login.signin-btn-login--filled(type='submit')
                  i.fas.fa-mobile-alt
                  | &nbsp; SEND OTP CODE TO MY CELL

            .signin-form-success#signin-cell-success(style='display:none;')
              .signin-success-icon
                i.fas.fa-mobile-alt
              h3.signin-success-title Enter the code
              p.signin-success-text We sent a 6-digit code to #[strong#signin-cell-display-value].
              .signin-otp-group
                each i in [1, 2, 3, 4, 5, 6]
                  input.signin-otp-input(type='text' inputmode='numeric' maxlength='1' aria-label='Digit ' + i)
              .signin-form-actions
                button.signin-btn-back(type='button' onclick='showAllSignInOptions()' aria-label='Back')
                  i.fas.fa-arrow-left
                button.btn.signin-btn-login(type='button')
                  i.fas.fa-check
                  | &nbsp; VERIFY

          .signin-or-divider
            span OR

          //- Email / Password toggle button
          button.btn.signin-btn-login#signin-email-toggle(type='button' onclick='showSignInForm("email")')
            i.fas.fa-envelope
            | &nbsp; SIGN IN WITH EMAIL & PASSWORD

          //- Email / Password form (hidden by default)
          form#signin-email-form(method='post' style='display:none;')
            .signin-input-group
              i.fas.fa-envelope.signin-input-icon
              input.signin-input(type='email' placeholder='Email' required)

            .signin-input-group
              i.fas.fa-lock.signin-input-icon
              input.signin-input#signin-password(type='password' placeholder='Password' required)
              button.signin-toggle-password(type='button' onclick='togglePassword()')
                i.fas.fa-eye#password-eye-icon

            .d-flex.justify-content-between.align-items-center.mb-4
              .custom-control.custom-checkbox
                input.custom-control-input(type='checkbox' id='remember_me' checked)
                label.custom-control-label(for='remember_me') Remember me
              span.signin-forgot-text Forgot password?&nbsp;
                a.signin-forgot-link(href='account-password-recovery.html') Click here.

            .signin-form-actions
              button.signin-btn-back(type='button' onclick='showAllSignInOptions()' aria-label='Back')
                i.fas.fa-arrow-left
              button.btn.signin-btn-login.signin-btn-login--filled(type='submit')
                i.fas.fa-envelope
                | &nbsp; SIGN IN


  //- Dev toggle (simulates an unknown account — fires the error state on submit)
  .signin-dev-toggle
    label
      input(type='checkbox' id='dev-unknown-account')
      span DEV: simulate unknown account

  //- Password toggle script
  script.
    var SIGNIN_OPTION_NAMES = ['magic', 'cell', 'email'];

    function setSignInOptionsVisible(visible) {
      var display = visible ? '' : 'none';
      var google = document.querySelector('.signin-google-btn');
      if (google) google.style.display = display;
      document.querySelectorAll('.signin-card .signin-or-divider').forEach(function (divider) {
        divider.style.display = display;
      });
      SIGNIN_OPTION_NAMES.forEach(function (name) {
        var btn = document.getElementById('signin-' + name + '-toggle');
        if (btn) btn.style.display = display;
        var helper = document.getElementById('signin-' + name + '-helper');
        if (helper) helper.style.display = display;
      });
    }

    function showSignInForm(name) {
      setSignInOptionsVisible(false);
      SIGNIN_OPTION_NAMES.forEach(function (other) {
        var form = document.getElementById('signin-' + other + '-form');
        if (form) form.style.display = (other === name) ? 'block' : 'none';
      });
      var activeForm = document.getElementById('signin-' + name + '-form');
      if (activeForm) {
        var firstInput = activeForm.querySelector('.signin-input');
        if (firstInput) firstInput.focus();
      }
    }

    function showAllSignInOptions() {
      SIGNIN_OPTION_NAMES.forEach(function (name) {
        var form = document.getElementById('signin-' + name + '-form');
        if (form) form.style.display = 'none';
      });
      resetSignInForm('magic');
      resetSignInForm('cell');
      setSignInOptionsVisible(true);
    }

    function resetSignInForm(name) {
      var entry = document.getElementById('signin-' + name + '-entry');
      var success = document.getElementById('signin-' + name + '-success');
      var errorBox = document.getElementById('signin-' + name + '-error');
      var robot = document.getElementById('signin-' + name + '-robot');
      if (entry) entry.style.display = '';
      if (success) success.style.display = 'none';
      if (errorBox) errorBox.style.display = 'none';
      if (robot) robot.checked = false;
      if (entry) {
        var submitBtn = entry.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = false;
      }
      if (success) {
        success.querySelectorAll('.signin-otp-input').forEach(function (i) { i.value = ''; });
      }
    }

    function handleSignInSubmit(event, name) {
      event.preventDefault();
      var devUnknown = document.getElementById('dev-unknown-account');
      var entry = document.getElementById('signin-' + name + '-entry');

      // Dev toggle ON: simulate the unknown-account error state
      if (devUnknown && devUnknown.checked) {
        var errorBox = document.getElementById('signin-' + name + '-error');
        if (!errorBox || errorBox.style.display === 'block') return;
        errorBox.style.display = 'block';
        if (entry) {
          var errSubmit = entry.querySelector('button[type="submit"]');
          if (errSubmit) errSubmit.disabled = true;
        }
        var errRobot = document.getElementById('signin-' + name + '-robot');
        if (errRobot) errRobot.checked = false;
        return;
      }

      // Normal flow: transition to the success state and echo the value
      var success = document.getElementById('signin-' + name + '-success');
      var input = entry ? entry.querySelector('.signin-input') : null;
      var value = input ? input.value.trim() : '';
      var display = document.getElementById('signin-' + name + '-display-value');
      if (display) display.textContent = value || (name === 'cell' ? 'your phone' : 'your email');
      if (entry) entry.style.display = 'none';
      if (success) success.style.display = 'block';
      if (name === 'cell' && success) {
        var firstOtp = success.querySelector('.signin-otp-input');
        if (firstOtp) firstOtp.focus();
      }
    }

    function initSignInForm(name) {
      var form = document.getElementById('signin-' + name + '-form');
      if (!form) return;
      form.addEventListener('submit', function (e) { handleSignInSubmit(e, name); });
      var robot = document.getElementById('signin-' + name + '-robot');
      if (robot) {
        robot.addEventListener('change', function () {
          var errorBox = document.getElementById('signin-' + name + '-error');
          if (!errorBox || errorBox.style.display !== 'block') return;
          var entry = document.getElementById('signin-' + name + '-entry');
          var submitBtn = entry ? entry.querySelector('button[type="submit"]') : null;
          if (submitBtn) submitBtn.disabled = !robot.checked;
        });
      }
    }

    function initOtpGroup(containerSelector) {
      var container = document.querySelector(containerSelector);
      if (!container) return;
      var inputs = container.querySelectorAll('.signin-otp-input');
      if (!inputs.length) return;
      inputs.forEach(function (input, idx) {
        input.addEventListener('input', function (e) {
          var digits = e.target.value.replace(/\D/g, '');
          e.target.value = digits.slice(-1);
          if (digits && idx < inputs.length - 1) {
            inputs[idx + 1].focus();
          }
        });
        input.addEventListener('keydown', function (e) {
          if (e.key === 'Backspace' && !e.target.value && idx > 0) {
            inputs[idx - 1].focus();
          } else if (e.key === 'ArrowLeft' && idx > 0) {
            inputs[idx - 1].focus();
          } else if (e.key === 'ArrowRight' && idx < inputs.length - 1) {
            inputs[idx + 1].focus();
          }
        });
        input.addEventListener('paste', function (e) {
          e.preventDefault();
          var pasted = ((e.clipboardData || window.clipboardData).getData('text') || '').replace(/\D/g, '').slice(0, inputs.length);
          if (!pasted) return;
          for (var i = 0; i < pasted.length; i++) {
            inputs[i].value = pasted[i];
          }
          var target = Math.min(pasted.length, inputs.length - 1);
          inputs[target].focus();
        });
      });
    }

    document.addEventListener('DOMContentLoaded', function () {
      initSignInForm('magic');
      initSignInForm('cell');
      initOtpGroup('#signin-cell-success .signin-otp-group');
    });

    function togglePassword() {
      var input = document.getElementById('signin-password');
      var icon = document.getElementById('password-eye-icon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
      }
    }
